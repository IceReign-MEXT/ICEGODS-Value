import time
import requests

def get_lido_apr():
    return 6.9

def get_raydium_farms_apr():
    try:
        response = requests.get("https://api.raydium.io/farms")
        if response.ok:
            farms = response.json()
            aprs = [f.get("apr") for f in farms if f.get("status")=="active"]
            return aprs if aprs else ["No active farms found"]
    except:
        return ["API unreachable, simulated farms: 20%, 25%, 30%"]
    return ["N/A"]

while True:
    lido_apr = get_lido_apr()
    raydium_aprs = get_raydium_farms_apr()
    
    print(f"📈 Lido staking APR: {lido_apr}%")
    print(f"💎 Raydium active farm APRs: {raydium_aprs}")
    print("-"*50)
    
    time.sleep(60*10)
